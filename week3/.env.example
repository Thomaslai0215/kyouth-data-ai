# Used for local uv run and for docker compose variable substitution.
# Sensitive values in Docker use secrets/google_api_key.txt instead (see secrets/).

# Host port for the chat UI — must match FRONTEND_PORT mapping in docker-compose.yml
FRONTEND_PORT=8000

# Host port for the backend API — must match the port number in BACKEND_URL below
BACKEND_PORT=8001
# Browser calls the backend from the host, so use localhost (not the Docker service name)
BACKEND_URL=http://localhost:8001/chat

# LLM for chat and skill-gap extraction (Gemini if name starts with "gemini-", else Ollama)
CHAT_MODEL=llama3.1

# Required for find_skill_gaps (local uv run). For Docker, use secrets/google_api_key.txt
GOOGLE_API_KEY=

# Local Ollama when running backend with uv (not Docker)
OLLAMA_BASE_URL=http://127.0.0.1:11434
