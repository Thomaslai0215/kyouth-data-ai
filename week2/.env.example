# Copy this file to .env and fill in your values.
# Do not commit .env — it is listed in .gitignore.

# Required for Gemini tagging (tag_data.py) and prompt_model.py
GOOGLE_API_KEY=

# Optional: use the shorter optimized prompt (fewer tokens, faster).
# Accepted values: 1, true, yes (case-insensitive). Leave empty for baseline prompt.
TAG_OPTIMIZED=1
